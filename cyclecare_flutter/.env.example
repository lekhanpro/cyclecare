# CycleCare AI Configuration
# Copy this file to .env and fill in your values.
# If left empty, the AI assistant will show an offline/disabled state.

# OpenAI-compatible API key (e.g., OpenAI, Groq, Azure, self-hosted).
# Put the real key in .env.local, which is gitignored.
AI_API_KEY=your-openai-compatible-api-key-here

# Base URL for the API.
# OpenAI: https://api.openai.com
# Groq keys usually start with gsk_ and use: https://api.groq.com/openai
AI_BASE_URL=https://api.openai.com

# Model name.
# OpenAI default: gpt-4o-mini
# Groq example: llama-3.1-8b-instant
AI_MODEL=gpt-4o-mini
