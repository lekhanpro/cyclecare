# CycleCare AI Configuration
# Copy this file to .env and fill in your values.
# If left empty, the AI assistant will show an offline/disabled state.

# OpenAI-compatible API key (e.g., OpenAI, Groq, Azure, self-hosted)
AI_API_KEY=your-openai-compatible-api-key-here

# Base URL for the API (default: https://api.openai.com)
AI_BASE_URL=https://api.openai.com

# Model name (default: gpt-4o-mini)
AI_MODEL=gpt-4o-mini
