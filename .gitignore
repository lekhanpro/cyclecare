# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Generated files
*.g.dart
*.freezed.dart
*.mocks.dart

# Database
*.db
*.db-shm
*.db-wal

# Temporary files
tmp/
.jdk/
.gradle-cache/

# Local secrets and build config. Never commit real API keys.
.env
.env.*
*.env.local
*.local.env
ai_config.local.json

# Android signing — never commit these
android/key.properties
android/app/*.jks
android/app/*.keystore

# Environment variables
.env

# Build outputs
build/

# Gradle
.gradle/

# Large planning docs (keep in local only)
MASTER_IMPLEMENTATION_PLAN.pdf
MASTER_IMPLEMENTATION_PLAN.tex

# Generated icon script output (large PNG)
assets/images/app_icon.png

# Scripts that contain local paths
scripts/create_placeholder_icon.dart
scripts/make_icon.dart

# Keystore base64 (for GitHub secrets setup — never commit)
scripts/keystore_base64.txt
